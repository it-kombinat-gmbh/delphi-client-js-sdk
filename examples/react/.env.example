VITE_API_DOMAIN=api.example.com
VITE_API_KEY=ysk_live_XXXX

# Optional: pre-fills the endpoint ID input in the read-aloud demo
# VITE_DEFAULT_ENDPOINT_ID=00000000-0000-0000-0000-000000000000

# The WebRTC gateway URL is not a client-side env var — the server
# returns it in the session-token response per call. Configure it on
# your TelAPI deployment instead.

# Optional: TURN credential (pass iceServers directly in config for full control)
# VITE_TURN_USERNAME=user
# VITE_TURN_CREDENTIAL=secret
